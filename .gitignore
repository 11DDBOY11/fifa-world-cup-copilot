# ============================================================
# Fan Copilot — .gitignore
# ============================================================

# ── Secrets ─────────────────────────────────────────────────
backend/.env
frontend/.env

# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build output ─────────────────────────────────────────────
dist/
backend/dist/
frontend/dist/

# ── Database (SQLite — runtime-generated, not committed) ──────
data/
backend/data/
*.db
*.sqlite

# ── RAG vector index (generated by build-index.ts) ───────────
backend/src/rag/index/

# ── Test & debug scripts (kept locally, not shipped) ─────────
backend/src/rag/test-task1.ts
backend/src/rag/test-task3.ts
backend/src/rag/test-task4.ts
backend/src/rag/test-nav-and-rag.ts
backend/src/rag/test-rag-dedup.ts
backend/src/rag/test-crowd.ts
backend/src/rag/test-db-v12.ts
backend/src/rag/test-memory.ts
backend/src/rag/debug-apis.ts
backend/src/rag/debug-maps-key.ts
backend/src/rag/debug-routes.ts
backend/src/rag/stub-server.ts

# ── OS / editor noise ────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
